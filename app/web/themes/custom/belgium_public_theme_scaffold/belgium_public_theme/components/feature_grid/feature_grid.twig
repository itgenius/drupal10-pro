<section class="feature-grid-section">
  <div class="container">
    {% include 'belgium_public_theme:section_title' with { title: title, summary: summary } only %}
    <div class="feature-grid">
      {% for item in items %}
        <article class="feature-card">
          {% if item.icon %}<div class="feature-card__icon">{{ item.icon }}</div>{% endif %}
          <h3>{{ item.title }}</h3>
          <p>{{ item.summary }}</p>
          {% if item.link_url and item.link_label %}
            <a href="{{ item.link_url }}">{{ item.link_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>
