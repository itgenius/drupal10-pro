{#
  Institution page template
  Regions:
  - header: language switcher block
  - primary_menu: main navigation block
  - content
  - footer
#}

<header class="site-header" role="banner">
  <div class="container">

    {# Top bar: Brand + Tools #}
    <div class="site-header__top">
      <a class="brand" href="{{ path('<front>') }}" aria-label="{{ 'Home'|t }}">
        <span class="brand__logo" aria-hidden="true"></span>
        <span class="brand__title">
          <span class="brand__name">{{ site_name }}</span>
          <span class="brand__tagline">{{ 'Site institutionnel'|t }}</span>
        </span>
      </a>

      <div class="site-tools">
        {# Search drawer toggle (no inline search input) #}
        <button class="btn btn-ghost search-toggle" type="button" aria-haspopup="dialog" aria-controls="search-drawer">
          {{ 'Search'|t }}
        </button>

        {# Language switcher block placed in region Header #}
        <div class="lang-switch" aria-label="{{ 'Language switcher'|t }}">
          {{ page.header }}
        </div>

        {# Mobile menu toggle (optional later) #}
        <button class="btn btn-ghost menu-toggle" type="button" aria-label="{{ 'Open menu'|t }}">
          ☰
        </button>
      </div>
    </div>

    {# Main navigation: ONE place only #}
    <nav class="site-nav" aria-label="{{ 'Primary navigation'|t }}">
      {{ page.primary_menu }}
    </nav>

  </div>
</header>

{# Search Drawer (overlay) #}
<div class="drawer-backdrop" data-drawer-close hidden></div>

<div class="drawer" id="search-drawer" role="dialog" aria-modal="true" aria-label="{{ 'Search'|t }}" hidden>
  <div class="drawer__header">
    <h2 class="drawer__title">{{ 'Search'|t }}</h2>
    <button class="btn btn-ghost" type="button" data-drawer-close aria-label="{{ 'Close'|t }}">✕</button>
  </div>

  <form class="drawer-search" action="/recherche" method="get" role="search">
    <label class="visually-hidden" for="q">{{ 'Search'|t }}</label>
    <input id="q" name="search_api_fulltext" type="search" placeholder="{{ 'Search…'|t }}">
    <button class="btn btn-primary" type="submit">{{ 'Search'|t }}</button>

    <p class="text-muted" style="margin-top: var(--space-3);">
      {{ 'Tip: you can filter results on the search page.'|t }}
    </p>
  </form>
</div>

<main role="main">
  <div class="container" style="padding: var(--space-8) 0;">
    {{ page.content }}
  </div>
</main>

<footer role="contentinfo" class="site-footer">
  <div class="container">
    {{ page.footer }}
  </div>
</footer>